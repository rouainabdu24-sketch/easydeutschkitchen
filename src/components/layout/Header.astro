---
import { CATEGORIES } from '../../lib/categories';

const navLinks = [
  { href: '/rezepte/', label: 'Alle Rezepte' },
  { href: '/kategorie/hauptgerichte/', label: 'Hauptgerichte' },
  { href: '/kategorie/backwaren/', label: 'Backwaren' },
  { href: '/kategorie/desserts/', label: 'Desserts' },
  { href: '/ueber-uns/', label: 'Über uns' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-amber-100 sticky top-0 z-50 shadow-sm">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-amber-700 hover:text-amber-800">
        <span class="text-2xl">🥨</span>
        <span>EasyDeutschKitchen</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Hauptnavigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors ${
              currentPath.startsWith(link.href)
                ? 'text-amber-700 border-b-2 border-amber-700 pb-0.5'
                : 'text-gray-600 hover:text-amber-700'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Search icon -->
      <a
        href="/suche/"
        class="flex items-center gap-2 px-3 py-2 rounded-lg bg-amber-50 text-amber-700 hover:bg-amber-100 transition-colors text-sm font-medium"
        aria-label="Rezepte suchen"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="hidden sm:inline">Suchen</span>
      </a>
    </div>

    <!-- Mobile nav -->
    <nav class="md:hidden flex gap-4 pb-3 overflow-x-auto" aria-label="Mobile Navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-xs font-medium whitespace-nowrap transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-amber-700'
              : 'text-gray-600'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
