---
import { SITE_NAME, SITE_DESCRIPTION } from '../../lib/utils';
---

<footer class="bg-amber-900 text-amber-100 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2 font-bold text-xl text-white mb-3">
          <span class="text-2xl">🥨</span>
          <span>{SITE_NAME}</span>
        </div>
        <p class="text-amber-200 text-sm leading-relaxed mb-4">{SITE_DESCRIPTION}</p>
        <a
          href="/about/"
          class="inline-flex items-center gap-1 text-xs text-amber-300 hover:text-white transition-colors"
        >
          Meet the author →
        </a>
      </div>

      <!-- Recipes -->
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm uppercase tracking-wide">Rezepte</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/kategorie/hauptgerichte/" class="hover:text-white transition-colors">Hauptgerichte</a></li>
          <li><a href="/kategorie/suppen/" class="hover:text-white transition-colors">Suppen</a></li>
          <li><a href="/kategorie/backwaren/" class="hover:text-white transition-colors">Backwaren</a></li>
          <li><a href="/kategorie/desserts/" class="hover:text-white transition-colors">Desserts</a></li>
          <li><a href="/kategorie/fruehstueck/" class="hover:text-white transition-colors">Frühstück</a></li>
          <li><a href="/kategorie/beilagen/" class="hover:text-white transition-colors">Beilagen</a></li>
          <li><a href="/kategorie/snacks/" class="hover:text-white transition-colors">Snacks</a></li>
        </ul>
      </div>

      <!-- Blog -->
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm uppercase tracking-wide">Blog</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/rezepte/" class="hover:text-white transition-colors">Alle Rezepte</a></li>
          <li><a href="/about/" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/ueber-uns/" class="hover:text-white transition-colors">Über uns</a></li>
          <li><a href="/suche/" class="hover:text-white transition-colors">Suche</a></li>
          <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm uppercase tracking-wide">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/impressum/" class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="/disclaimer/" class="hover:text-white transition-colors">Disclaimer</a></li>
          <li><a href="/cookies/" class="hover:text-white transition-colors">Cookie Policy</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-amber-800 mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-amber-400">
      <p>&copy; {new Date().getFullYear()} {SITE_NAME}. Alle Rechte vorbehalten.</p>
      <div class="flex flex-wrap gap-4">
        <a href="/impressum/" class="hover:text-white transition-colors">Impressum</a>
        <a href="/privacy/" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms/" class="hover:text-white transition-colors">Terms</a>
        <a href="/disclaimer/" class="hover:text-white transition-colors">Disclaimer</a>
        <a href="/cookies/" class="hover:text-white transition-colors">Cookies</a>
        <a href="/contact/" class="hover:text-white transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
