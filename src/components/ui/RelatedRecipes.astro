---
import RecipeCard from './RecipeCard.astro';

interface RecipeEntry {
  id: string;
  data: {
    title: string;
    description: string;
    heroImage: string;
    heroImageAlt: string;
    category: string;
    prepTime: number;
    cookTime: number;
    servings: number;
    difficulty: string;
    pubDate: Date;
  };
}

interface Props {
  recipes: RecipeEntry[];
}

const { recipes } = Astro.props;
---

{recipes.length > 0 && (
  <section class="mt-12 no-print">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Ähnliche Rezepte</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {recipes.map(r => (
        <RecipeCard
          slug={r.id}
          title={r.data.title}
          description={r.data.description}
          heroImage={r.data.heroImage}
          heroImageAlt={r.data.heroImageAlt}
          category={r.data.category}
          prepTime={r.data.prepTime}
          cookTime={r.data.cookTime}
          servings={r.data.servings}
          difficulty={r.data.difficulty}
          pubDate={r.data.pubDate}
        />
      ))}
    </div>
  </section>
)}
