---
interface Props {
  rating?: number;
  maxStars?: number;
}

const { rating = 5, maxStars = 5 } = Astro.props;
const fullStars = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
---

<div class="flex items-center gap-1" aria-label={`Bewertung: ${rating} von ${maxStars} Sternen`} role="img">
  {Array.from({ length: maxStars }).map((_, i) => (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class={`w-5 h-5 ${i < fullStars ? 'text-amber-400' : (i === fullStars && hasHalf ? 'text-amber-300' : 'text-gray-200')}`}
      fill="currentColor"
    >
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
    </svg>
  ))}
  <span class="text-sm text-gray-500 ml-1">{rating}/{maxStars}</span>
</div>
