---
interface Props {
  type?: 'inpage' | 'inimage';
  class?: string;
}

const { type = 'inpage', class: className = '' } = Astro.props;
---

{type === 'inpage' && (
  <div class={`hb-ad-inpage my-6 ${className}`}>
    <div class="hb-ad-inner">
      <div class="hbagency_cls hbagency_space_272592"></div>
    </div>
  </div>
)}

{type === 'inimage' && (
  <div id='hbagency_space_272591' class={className}></div>
)}
