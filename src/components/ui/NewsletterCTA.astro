---
---

<section class="my-10 bg-amber-800 text-white rounded-2xl p-8 text-center no-print">
  <h2 class="text-2xl font-bold mb-2">Neue Rezepte direkt ins Postfach</h2>
  <p class="text-amber-200 mb-6 text-sm">Jede Woche neue deutsche Rezepte, Tipps und saisonale Ideen.</p>
  <form
    action="#"
    method="post"
    class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto"
    aria-label="Newsletter anmelden"
  >
    <input
      type="email"
      name="email"
      required
      placeholder="deine@email.de"
      class="flex-1 px-4 py-3 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-amber-300"
      aria-label="E-Mail-Adresse"
    />
    <button
      type="submit"
      class="px-6 py-3 bg-amber-500 text-white rounded-lg font-semibold text-sm hover:bg-amber-400 transition-colors"
    >
      Anmelden
    </button>
  </form>
  <p class="text-xs text-amber-300 mt-3">Kein Spam. Jederzeit abmeldbar.</p>
</section>
