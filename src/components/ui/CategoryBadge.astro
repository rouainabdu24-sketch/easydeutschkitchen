---
import { getCategoryLabel } from '../../lib/categories';

interface Props {
  category: string;
  href?: string;
}

const { category, href } = Astro.props;
const label = getCategoryLabel(category);
const url = href ?? `/kategorie/${category}/`;
---

<a
  href={url}
  class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-amber-100 text-amber-800 hover:bg-amber-200 transition-colors"
>
  {label}
</a>
