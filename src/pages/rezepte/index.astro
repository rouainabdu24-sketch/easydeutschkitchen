---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/ui/RecipeCard.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../lib/categories';
import { SITE_URL } from '../../lib/utils';

const allRecipes = await getCollection('recipes', r => !r.data.draft);
const sorted = allRecipes.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Alle Rezepte – Deutsche Küche"
  description="Entdecke alle unsere deutschen Rezepte: von Hauptgerichten und Suppen bis zu Desserts und Backwaren. Authentisch, einfach und lecker."
  canonicalURL={`${SITE_URL}/rezepte/`}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumbs crumbs={[{ label: 'Rezepte' }]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Alle Rezepte</h1>
    <p class="text-gray-500 mb-8">{sorted.length} Rezepte</p>

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a href="/rezepte/" class="px-4 py-2 rounded-lg bg-amber-600 text-white text-sm font-medium">
        Alle
      </a>
      {CATEGORIES.map(cat => (
        <a
          href={`/kategorie/${cat.slug}/`}
          class="px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-amber-300 hover:text-amber-700 transition-colors"
        >
          {cat.emoji} {cat.label}
        </a>
      ))}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {sorted.map(r => (
        <RecipeCard
          slug={r.id}
          title={r.data.title}
          description={r.data.description}
          heroImage={r.data.heroImage}
          heroImageAlt={r.data.heroImageAlt}
          category={r.data.category}
          prepTime={r.data.prepTime}
          cookTime={r.data.cookTime}
          servings={r.data.servings}
          difficulty={r.data.difficulty}
          pubDate={r.data.pubDate}
        />
      ))}
    </div>
  </div>
</BaseLayout>
