---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/ui/RecipeCard.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import { CATEGORIES } from '../../lib/categories';
import { SITE_URL } from '../../lib/utils';

export async function getStaticPaths() {
  const allRecipes = await getCollection('recipes', r => !r.data.draft);
  return CATEGORIES.map(cat => ({
    params: { category: cat.slug },
    props: {
      categoryLabel: cat.label,
      categoryDescription: cat.description,
      recipes: allRecipes
        .filter(r => r.data.category === cat.slug)
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

const { category } = Astro.params;
const { categoryLabel, categoryDescription, recipes } = Astro.props;
const pageUrl = `${SITE_URL}/kategorie/${category}/`;
---

<BaseLayout
  title={`${categoryLabel} – Deutsche Rezepte`}
  description={`${categoryDescription}. Alle ${categoryLabel}-Rezepte auf EasyDeutschKitchen – authentisch, einfach und lecker.`}
  canonicalURL={pageUrl}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumbs crumbs={[
      { label: 'Rezepte', href: '/rezepte/' },
      { label: categoryLabel },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">{categoryLabel}</h1>
    <p class="text-gray-500 mb-8">{recipes.length} Rezepte · {categoryDescription}</p>

    {recipes.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {recipes.map(r => (
          <RecipeCard
            slug={r.id}
            title={r.data.title}
            description={r.data.description}
            heroImage={r.data.heroImage}
            heroImageAlt={r.data.heroImageAlt}
            category={r.data.category}
            prepTime={r.data.prepTime}
            cookTime={r.data.cookTime}
            servings={r.data.servings}
            difficulty={r.data.difficulty}
            pubDate={r.data.pubDate}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500">Noch keine Rezepte in dieser Kategorie. Bald mehr!</p>
    )}
  </div>
</BaseLayout>
